def entropy_from_p(p):
    with np.errstate(divide='ignore', invalid='ignore'):
        H = -(p * np.log2(p + 1e-15) + (1 - p) * np.log2(1 - p + 1e-15))
    H[np.isclose(H, 0.0, atol=1e-12)] = 0.0
    return H


