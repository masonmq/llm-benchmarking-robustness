    for i in range(n_vars):
        for j in range(n_vars):
            denom = norms[i] * norms[j]
            if denom == 0.0:
                S[i, j] = 0.0
            else:
                S[i, j] = float(np.dot(X[:, i], X[:, j]) / denom)
    return S

