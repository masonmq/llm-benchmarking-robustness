  dplyr::select('hhcode', 'domlow')

selected_table2 <- table2 %>%
  dplyr::select('hhcode', 'domhigh')

check <- left_join(selected_table2, selected, by='hhcode')

############### Are there any inconsistencies across domlow and domhigh?
check <- check %>%
  mutate(Different = if_else(domlow == domhigh, 1, 0))
############### Is there a missing in one dataset but not the other?
check <- check %>%
  mutate(Different = if_else(!is.na(domlow) & is.na(domhigh) | is.na(domlow) & !is.na(domhigh) , 1, 0))
table(check$Different)

####### There are two cases of households that are missing from the main dataframe but not from Table 2
which_missing <- check %>%
  filter(Different == TRUE)
table(which_missing$hhcode)
