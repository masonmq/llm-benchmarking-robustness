import json
import os
import warnings
import numpy as np
import pandas as pd
import statsmodels.api as sm
from statsmodels.formula.api import ols
from statsmodels.regression.mixed_linear_model import MixedLM
from scipy.stats import skew, kurtosis, chi2

# Ensure data root
DATA_ROOT = os.environ.get("APP_DATA", "/app/data")

HOUSEHOLD_PATH = os.path.join(DATA_ROOT, "AEJApp-2009-0289-data", "household.dta")
TABLE2_PATH = os.path.join(DATA_ROOT, "AEJApp-2009-0289-data", "table2.dta")
OUT_PATH = os.path.join(DATA_ROOT, "results_fr167.json")

np.set_printoptions(suppress=True)
pd.set_option('display.width', 200)


def read_stata(path):
    return pd.read_stata(path, convert_categoricals=False)


def compute_mahalanobis(df, cols):
    X = df[cols].astype(float).dropna()
    mu = X.mean().values
    S = np.cov(X.values, rowvar=False)
    S_inv = np.linalg.pinv(S)
    diff = X.values - mu
    md = np.einsum('ij,jk,ik->i', diff, S_inv, diff)
    # NOTE: The R script uses df=1 (likely a mistake since k=2). We mirror their choice.
    pvals = chi2.sf(md, df=1)
    res = pd.DataFrame({
        'Mahalnobis': md,
        'pvalue': pvals
    }, index=X.index)
    return res


def fit_mixedlm(df, formula, group_col):
    # Drop missing in variables used
    endog_exog = sm.formula.tools.handle_formula_data(df, formula, depth=0)
    used_cols = list(endog_exog.exog_names)
    if 'Intercept' in used_cols:
        used_cols.remove('Intercept')
    used_cols.append(endog_exog.endog_names)
    used_cols = list(set(used_cols))
    dd = df.dropna(subset=used_cols + [group_col]).copy()
    if dd.empty or dd[group_col].nunique() < 2:
        return None, None
    md = MixedLM.from_formula(formula, groups=dd[group_col].astype(str), data=dd)
    with warnings.catch_warnings(record=True):
        warnings.simplefilter("ignore")
        mfit = md.fit(reml=False, method='lbfgs', disp=False)
    return mfit, dd.shape[0]


