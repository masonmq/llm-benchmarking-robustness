import json
import math
import numpy as np
import pandas as pd
from scipy import stats
import statsmodels.api as sm

DATA_PATH = "/app/data/1-s2.0-S1090513816301118-mmc1.csv"
OUTPUT_PATH = "/app/data/task1_results.json"


def partial_corr_resid(x, y, z):
    """Compute partial correlation r(x,y|z) using residuals and return (r, p, n, df)."""
    # Drop NaNs jointly
    df = pd.DataFrame({"x": x, "y": y, "z": z}).dropna()
    n = df.shape[0]
    if n < 4:
        return np.nan, np.nan, n, np.nan
    # Residualize x on z
    Xz = sm.add_constant(df[["z"]])
    bx = sm.OLS(df["x"], Xz, missing="drop").fit()
    by = sm.OLS(df["y"], Xz, missing="drop").fit()
    rx = bx.resid
    ry = by.resid
    r, _ = stats.pearsonr(rx, ry)
    # Degrees of freedom for partial corr with 1 control: n - 3
    dof = n - 3
    if dof <= 0:
        return r, np.nan, n, dof
    if abs(r) == 1:
        p = 0.0
    else:
        t_stat = r * math.sqrt(dof / (1.0 - r ** 2))
        p = 2 * stats.t.sf(abs(t_stat), dof)
    return r, p, n, dof


def ols_with_controls(y, x, controls):
    df = pd.concat([y, x, controls], axis=1).dropna()
    yv = df[y.name]
    Xv = sm.add_constant(df[[x.name] + list(controls.columns)])
    model = sm.OLS(yv, Xv).fit()
    # Standardized beta for main predictor
    std_y = yv.std(ddof=0)
    std_x = df[x.name].std(ddof=0)
    beta_unstd = model.params.get(x.name, np.nan)
    beta_std = np.nan
    if pd.notnull(beta_unstd) and std_y not in (0, np.nan) and std_x not in (0, np.nan):
        beta_std = beta_unstd * (std_x / std_y)
    return {
        "n": int(df.shape[0]),
        "coef": float(beta_unstd) if pd.notnull(beta_unstd) else np.nan,
        "se": float(model.bse.get(x.name, np.nan)),
        "t": float(model.tvalues.get(x.name, np.nan)),
        "p": float(model.pvalues.get(x.name, np.nan)),
        "beta_std": float(beta_std) if pd.notnull(beta_std) else np.nan,
        "r2": float(model.rsquared),
        "adj_r2": float(model.rsquared_adj)
    }


