import json
import numpy as np
import pandas as pd
from scipy import stats

DATA_PATH = "/app/data/1-s2.0-S1090513816301118-mmc1.csv"
OUTPUT_PATH = "/app/data/task2_results.json"


def partial_corr(x, y, z):
    df = pd.DataFrame({"x": x, "y": y, "z": z}).dropna()
    if df.shape[0] < 4:
        return {"r": np.nan, "p": np.nan, "n": int(df.shape[0])}
    # Residualize and correlate
    Xz = np.column_stack([np.ones(df.shape[0]), df["z"].values])
    # regress x on z
    bx, _, _, _ = np.linalg.lstsq(Xz, df["x"].values, rcond=None)
    by, _, _, _ = np.linalg.lstsq(Xz, df["y"].values, rcond=None)
    rx = df["x"].values - Xz.dot(bx)
    ry = df["y"].values - Xz.dot(by)
    r, p = stats.pearsonr(rx, ry)
    return {"r": float(r), "p": float(p), "n": int(df.shape[0])}


def main():
    data = pd.read_csv(DATA_PATH)
    age = data["Age"] if "Age" in data.columns else None
    dsm5_total = data["DSM5_Total"] if "DSM5_Total" in data.columns else None
    minik_total = data["MiniK_Total"] if "MiniK_Total" in data.columns else None

    if age is None or dsm5_total is None or minik_total is None:
        raise RuntimeError("Required columns missing: Age, DSM5_Total, MiniK_Total.")

    res = partial_corr(minik_total, dsm5_total, age)
    results = {
        "notes": "Task2: partial correlation between MiniK_Total and DSM5_Total controlling Age.",
        "partial_corr_minik_dsm5_age": res
    }

    with open(OUTPUT_PATH, "w") as f:
        json.dump(results, f, indent=2)

    print(json.dumps(results, indent=2))


if __name__ == "__main__":
    main()

